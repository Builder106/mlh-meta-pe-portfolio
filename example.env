URL=localhost:5000

# MySQL — see Week 4 "Adding Database #1" for how to install and set these up.
# Running via `docker compose up` (Week 6)? MYSQL_HOST should be the "mysql"
# service name, not localhost — the app reaches it over the compose network.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=myportfoliodb
MYSQL_USER=myportfolio
MYSQL_PASSWORD=mypassword
MYSQL_ROOT_PASSWORD=changeme

# Week 6 Task 3 — nginx-certbot. Only used by the prod compose file's nginx
# service (Let's Encrypt registration contact); unused in local dev.
CERTBOT_EMAIL=you@example.com